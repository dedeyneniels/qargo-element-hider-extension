{
  "manifest_version": 3,
  "name": "Qargo Element Hider",
  "version": "1.2",
  "permissions": ["storage"],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ],
  "action": { "default_popup": "popup.html" },
  "content_scripts": [{ 
    "matches": ["https://app.qargo.com/*"], 
    "js": ["content.js"] 
  }]
}